    42                                      ; here to get absolute of (xe - xs) we have to do
    43                                      ; ((xe - xs XOR (xe - xs)>>31)) - (xe - xs>>31)
    44                                  
    45 00000049 89C6                        mov     esi, eax ; store xe - xs in esi
    46 0000004B 89CF                        mov     edi, ecx ; store ye - ys in edi
