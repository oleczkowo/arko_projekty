    76                                  
    77                                  ; I have to take into account, that xs might still be bigger than xe, even after swapping for fe. vertical ye < ys.
    78                                  ; This would mean, that the gradient would be negative, which is bad considering I'm working on unsigned integers.
    79                                  
    80                                  is_positive_dx:
    81 00000085 8B450C                      mov     eax, [ebp + 12]
    82 00000088 8B5D14                      mov     ebx, [ebp + 20]
    83 0000008B 39D8                        cmp     eax, ebx ; if xs > xe, dx has to be xs-xe instead of xe-xs.
    84 0000008D 720D                        jb     calculate_dx
