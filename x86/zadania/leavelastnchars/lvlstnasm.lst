     1                                  section .text
     2                                      global lvlstnasm
     3                                  
     4                                  lvlstnasm:
     5 00000000 55                          push ebp ; odtwórz ebp
     6 00000001 89E5                        mov ebp, esp ; rusz esp do ebp
     7                                  
     8 00000003 53                          push ebx
     9 00000004 56                          push esi
    10                                  
    11 00000005 8B4508                      mov eax, [ebp + 8] ; wskaźnik na string wejściowy
    12 00000008 8B7508                      mov esi, [ebp + 8] ; wskaźnik na string wejściowy (zapisujący)
    13 0000000B 8A4D0C                      mov cl, [ebp + 12] ; wskaźnik na int wejściowy
    14 0000000E B500                        mov ch, 0 ; counter ilości cyfr
    15                                  
    16                                  count_word_digit:
    17 00000010 8A18                        mov bl, [eax] ; załaduj bajt stringa
    18 00000012 40                          inc eax ; zinkrementuj eax
    19 00000013 84DB                        test bl, bl ; sprawdź, czy bajt jest nullptr
    20 00000015 7410                        jz fin_count_digit ; jak tak, zakończ liczenie ilości liczb
    21 00000017 80FB30                      cmp bl, '0' ; sprawdzam, czy cyfra
    22 0000001A 7209                        jb not_digit
    23 0000001C 80FB39                      cmp bl, '9'
    24 0000001F 7F04                        jg not_digit
    25 00000021 FEC5                        inc ch ; jeżeli nie wykonaliśmy skoku, jest to cyfra, więc zinkrementuj counter
    26 00000023 EBEB                        jmp count_word_digit ; wróć do pętli
    27                                  
    28                                  not_digit:
    29 00000025 EBE9                        jmp count_word_digit
    30                                  
    31                                  fin_count_digit:
    32 00000027 48                          dec eax
    33 00000028 8B4508                      mov eax, [ebp + 8] ; wróć do argumentu wejściowego
    34 0000002B 38E9                        cmp cl, ch
    35 0000002D 7D25                        jge print_all_digits
    36 0000002F 28CD                        sub ch, cl ; odejmij counter ilości cyfr od podanej ilości zachowanych cyfr
    37                                  
    38                                  main_loop:
    39 00000031 8A18                        mov bl, [eax]
    40 00000033 40                          inc eax
    41 00000034 84DB                        test bl, bl
    42 00000036 7438                        jz finish
    43 00000038 80FB30                      cmp bl, '0'
    44 0000003B 720E                        jb delete
    45 0000003D 80FB39                      cmp bl, '9'
    46 00000040 7F09                        jg delete
    47 00000042 80FD00                      cmp ch, 0
    48 00000045 7606                        jbe save_digit
    49 00000047 FECD                        dec ch
    50 00000049 EBE6                        jmp main_loop
    51                                  
    52                                  delete:
    53 0000004B EBE4                        jmp main_loop
    54                                  
    55                                  save_digit:
    56 0000004D 88DA                        mov dl, bl
    57 0000004F 8816                        mov [esi], dl
    58 00000051 46                          inc esi
    59 00000052 EBDD                        jmp main_loop
    60                                  
    61                                  print_all_digits:
    62 00000054 8A18                        mov bl, [eax]
    63 00000056 40                          inc eax
    64 00000057 84DB                        test bl, bl
    65 00000059 7415                        jz finish
    66 0000005B 80FB30                      cmp bl, '0'
    67 0000005E 7207                        jb avoid
    68 00000060 80FB39                      cmp bl, '9'
    69 00000063 7F02                        jg avoid
    70                                  
    71 00000065 EB02                        jmp save
    72                                  
    73                                  avoid:
    74 00000067 EBEB                        jmp print_all_digits
    75                                  
    76                                  save:
    77 00000069 88DA                        mov dl, bl
    78 0000006B 8816                        mov [esi], dl
    79 0000006D 46                          inc esi
    80 0000006E EBE4                        jmp print_all_digits
    81                                  
    82                                  finish:
    83 00000070 48                          dec eax
    84 00000071 88DA                        mov dl, bl
    85 00000073 8816                        mov [esi], dl
    86 00000075 8B4508                      mov eax, [ebp + 8]
    87                                  
    88 00000078 5E                          pop esi
    89 00000079 5B                          pop ebx
    90                                  
    91 0000007A 5D                          pop ebp
    92 0000007B C3                          ret
    93                                  
    94                                  
    95                                  
    96                                  
