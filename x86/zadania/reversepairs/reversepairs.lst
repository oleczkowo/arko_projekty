     1                                  section .text
     2                                      global reversepairs
     3                                  
     4                                  reversepairs:
     5 00000000 55                          push ebp
     6 00000001 89E5                        mov ebp, esp
     7                                  
     8 00000003 53                          push ebx
     9                                  
    10 00000004 8B4508                      mov eax, [ebp + 8] ; pointer na input
    11                                  
    12                                  main_loop:
    13 00000007 8A18                        mov bl, [eax]
    14 00000009 84DB                        test bl, bl
    15 0000000B 7411                        jz fin
    16 0000000D 8A7801                      mov bh, [eax + 1]
    17 00000010 84FF                        test bh, bh
    18 00000012 740A                        jz fin
    19 00000014 8838                        mov [eax], bh
    20 00000016 885801                      mov [eax + 1], bl
    21 00000019 83C002                      add eax, 2
    22 0000001C EBE9                        jmp main_loop
    23                                  
    24                                  fin:
    25 0000001E 8B4508                      mov eax, [ebp + 8]
    26                                  
    27 00000021 5B                          pop ebx
    28                                  
    29 00000022 5D                          pop ebp
    30 00000023 C3                          ret
