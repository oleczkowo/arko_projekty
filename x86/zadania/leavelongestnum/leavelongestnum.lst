     1                                  section .text
     2                                      global leavelongestnum
     3                                  
     4                                  leavelongestnum:
     5                                  
     6 00000000 55                          push ebp
     7 00000001 89E5                        mov ebp, esp
     8                                  
     9 00000003 56                          push esi
    10 00000004 57                          push edi
    11 00000005 53                          push ebx
    12                                  
    13 00000006 8B4508                      mov eax, [ebp + 8] ; wskaźnik na input str
    14 00000009 8B7508                      mov esi, [ebp + 8] ; wskaźnik na input str (zapisujący)
    15                                  
    16 0000000C B500                        mov ch, 0 ; counter sekwencji
    17 0000000E B200                        mov dl, 0 ; długość max sekwencji
    18 00000010 B100                        mov cl, 0 ; miejsce początku max sekwencji (aktualne miejsce minus counter)
    19 00000012 B700                        mov bh, 0 ; miejsce wskaźnika eax
    20                                  
    21                                  start:
    22 00000014 8A18                        mov bl, [eax] ; załaduj bajt do bl
    23 00000016 40                          inc eax ; inkrementuj wskaźnik
    24 00000017 84DB                        test bl, bl ; sprawdź czy nullptr
    25 00000019 743B                        jz fin_analyze
    26 0000001B 80FB30                      cmp bl, '0' ; sprawdź czy cyfra
    27 0000001E 7207                        jb not_digit
    28 00000020 80FB39                      cmp bl, '9'
    29 00000023 7702                        ja not_digit
    30 00000025 EB04                        jmp sequence ; cyfra - rozpocznij sekwencję
    31                                  
    32                                  not_digit:
    33 00000027 FEC7                        inc bh ; zinkrementuj miejsce wskaźnika
    34 00000029 EBE9                        jmp start
    35                                  
    36                                  sequence:
    37 0000002B FEC7                        inc bh ; inkrementuj miejsce wskaźnika
    38 0000002D FEC5                        inc ch ; inkrementuj counter
    39 0000002F 8A18                        mov bl, [eax]
    40 00000031 40                          inc eax
    41 00000032 84DB                        test bl, bl
    42 00000034 740C                        jz end_seq ; przed tym była ostatnia cyfra w inpucie.
    43 00000036 80FB30                      cmp bl, '0' ; sprawdź czy cyfra
    44 00000039 7207                        jb end_seq
    45 0000003B 80FB39                      cmp bl, '9'
    46 0000003E 7702                        ja end_seq
    47 00000040 EBE9                        jmp sequence
    48                                  
    49                                  end_seq:
    50 00000042 38D5                        cmp ch, dl
    51 00000044 762C                        jbe no_max
    52 00000046 88F9                        mov cl, bh
    53 00000048 28E9                        sub cl, ch ; wyliczam miejsce maksymalnej sekwencji
    54 0000004A 88EA                        mov dl, ch ; ładuje nową długość maksymalnej sekwencji
    55 0000004C 30ED                        xor ch, ch ; zeruje counter sekwencji
    56 0000004E FEC7                        inc bh ; inkrementuje wskaźnik indeksu
    57 00000050 84DB                        test bl, bl
    58 00000052 7402                        jz fin_analyze
    59 00000054 EBBE                        jmp start
    60                                  
    61                                  fin_analyze:
    62 00000056 8B4508                      mov eax, [ebp + 8]
    63 00000059 0FB6C9                      movzx ecx, cl
    64 0000005C 01C8                        add eax, ecx
    65                                  
    66                                  write_max_seq:
    67 0000005E FECA                        dec dl
    68 00000060 8A18                        mov bl, [eax]
    69 00000062 881E                        mov [esi], bl
    70 00000064 46                          inc esi
    71 00000065 40                          inc eax
    72 00000066 84D2                        test dl, dl
    73 00000068 7402                        jz end_write
    74 0000006A EBF2                        jmp write_max_seq
    75                                  
    76                                  end_write:
    77 0000006C B300                        mov bl, 0
    78 0000006E 881E                        mov [esi], bl
    79 00000070 EB06                        jmp fin
    80                                  
    81                                  
    82                                  no_max:
    83 00000072 30ED                        xor ch, ch ; ani nie wyliczam miejsca max seq, ani nie ładuje nowej długości.
    84 00000074 FEC7                        inc bh
    85 00000076 EB9C                        jmp start
    86                                  
    87                                  
    88                                  fin:
    89 00000078 8B4508                      mov eax, [ebp + 8]
    90                                  
    91 0000007B 5B                          pop ebx
    92 0000007C 5F                          pop edi
    93 0000007D 5E                          pop esi
    94                                  
    95 0000007E 5D                          pop ebp
    96 0000007F C3                          ret
